rules_version = '2';

// Staff must be signed in (Firebase Auth, Google Sign-In) AND their email
// must be on the allowedStaff allowlist for every operation below. Every
// approved staff account currently has identical access - there is no
// admin/field-staff role distinction yet (see docs/Backlog.md).
service cloud.firestore {
  match /databases/{database}/documents {

    function isApprovedStaff() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/allowedStaff/$(request.auth.token.email));
    }

    // True only for a staff account whose OWN allowedStaff document has
    // role == 'admin' (bootstrapped manually via Console - see
    // docs/Config-Management.md "Staff account provisioning"). Lets an
    // admin approve/reject signupRequests and create new allowedStaff
    // entries from within the app itself, instead of every approval
    // needing a Console edit.
    function isAdmin() {
      return isApprovedStaff()
        && get(/databases/$(database)/documents/allowedStaff/$(request.auth.token.email)).data.role == 'admin';
    }

    // Admin-managed allowlist of approved staff emails, keyed by email
    // address. A signed-in user may always read their OWN entry (to check
    // their own approval status); an admin may additionally read ANY
    // entry - needed to check whether an allowedStaff doc already exists
    // for a given email before approving a signupRequests entry for it
    // (see adminApprovals.js approveRequest) - and create new entries, but
    // never list the roster or update/delete an existing entry from the
    // client - revoking access or editing roles stays a Console-only
    // action.
    match /allowedStaff/{email} {
      allow get: if request.auth != null && (request.auth.token.email == email || isAdmin());
      allow create: if isAdmin();
      // A signed-in user may update ONLY their own fcmTokens array (to
      // register/unregister this device for push notifications - see
      // docs/Push-Notifications.md) and nothing else on their own
      // document. role/addedAt stay immutable from the client either way,
      // so this can never be used to self-grant admin.
      allow update: if request.auth != null && request.auth.token.email == email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmTokens']);
      allow list, delete: if false;
    }

    // Created by a signed-in-but-unapproved user for themselves the first
    // time they're turned away (see public/js/lib/auth.js
    // recordSignupRequest), so an admin can see and act on it from
    // /admin/approvals. Only an admin can list the pending queue or
    // resolve (update) a request; a user may always read their own.
    match /signupRequests/{email} {
      allow get: if request.auth != null && (request.auth.token.email == email || isAdmin());
      allow list: if isAdmin();
      allow create: if request.auth != null && request.auth.token.email == email;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /farmers/{frn} {
      allow read: if isApprovedStaff();
      allow create: if isApprovedStaff()
        && request.resource.data.keys().hasAll(['frn', 'fullName', 'phone']);
      allow update: if isApprovedStaff();
      allow delete: if false;
    }

    match /purchases/{purchaseId} {
      allow read: if isApprovedStaff();
      allow create: if isApprovedStaff()
        && request.resource.data.keys().hasAll(['frn', 'product', 'weightKg', 'totalUgx']);
      // Update is needed for the reconciliation flow (resolving a
      // frnUnverified purchase once the correct farmer is confirmed).
      allow update: if isApprovedStaff();
      allow delete: if false;
    }

    // Retired: FRN minting no longer uses a shared server-side counter
    // (see docs/Database-Schema.md "devices/{deviceCode}"). Left in place,
    // unused, rather than deleted, in case any historical doc needs reading.
    match /counters/{counterId} {
      allow read: if isApprovedStaff();
      allow write: if false;
    }

    // Each device claims its own randomly-generated short code once, the
    // first time it has a connection (see device.js). create-only (not
    // update) so a device can never overwrite another device's
    // registration - if two devices happen to roll the same code, the
    // second device's claim is silently rejected (accepted low-probability
    // risk, not auto-recovered - see Risk-Register).
    match /devices/{deviceCode} {
      allow read: if isApprovedStaff();
      allow create: if isApprovedStaff();
      allow update, delete: if false;
    }

    // Admin-editable reference data (see docs/Database-Schema.md and
    // docs/Config-Management.md "Editing reference data") - drives the
    // Buy Produce and New Farmer forms' dropdown/choice options and, for
    // newFarmerFields, the New Farmer form's field set itself. Read-only
    // for the field app; entries are only ever added/edited/deactivated
    // via Firebase Console's Firestore Data tab (or the Admin SDK) until
    // the admin app exists - same pattern as allowedStaff.
    match /products/{productId} {
      allow read: if isApprovedStaff();
      allow write: if false;
    }
    match /grades/{gradeId} {
      allow read: if isApprovedStaff();
      allow write: if false;
    }
    match /paymentMethods/{methodId} {
      allow read: if isApprovedStaff();
      allow write: if false;
    }
    match /farmSizes/{sizeId} {
      allow read: if isApprovedStaff();
      allow write: if false;
    }
    match /districts/{districtId} {
      allow read: if isApprovedStaff();
      allow write: if false;
    }
    match /newFarmerFields/{fieldId} {
      allow read: if isApprovedStaff();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
